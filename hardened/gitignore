# Obsidian workspace state (per-machine; do not sync)
.obsidian/workspace.json
.obsidian/workspace-mobile.json
.obsidian/workspaces.json
.obsidian/graph.json

# Obsidian community plugin data that is per-machine
.obsidian/plugins/*/data.json

# macOS
.DS_Store

# Editor scratch
*.swp
*.swo
.idea/
.vscode/

# Local-only secrets / credentials
.env
.env.local
secrets/

# Legacy dashboard generator output (removed 2026-05-18 — kept gitignored in
# case anyone resurrects the script). Dashboards are now emitted by Quartz.
_dashboards/

# Local Python venv (kept ignored in case scripts/ comes back).
.venv/

# Quartz build artifacts (re-installed/regenerated via npm install + quartz build)
quartz/node_modules/
quartz/public/
quartz/.quartz-cache/
quartz/tsconfig.tsbuildinfo
quartz/prof/

# Drop zone — the folder and its README are tracked, but everything
# else dropped here stays local. The triage workflow reads from this
# folder, moves binaries into Raw/<subfolder>/ (which IS tracked),
# extracts text into typed notes, and leaves the originals untracked.
Inbox/*
!Inbox/README.md

# Obsidian Daily Notes auto-creates these at root; keep them out of git
# so they don't drift into the commit log.
/today.md
/[0-9][0-9][0-9][0-9]-[0-9][0-9]-[0-9][0-9].md

# Generated letter artifacts (mail-merged docx, intermediate md) — content is local-only
outputs/**
!outputs/README.md

# Drafts — git-tracked staging area for finalize-later text/LLM drafts. Text
# (markdown, code, notes) IS committed so drafts are versioned across sessions;
# heavy binary types stay local-only — route real binary artifacts to outputs/.
# The folder and its README are tracked by default; only the binaries below are
# ignored.
Drafts/**/*.pdf
Drafts/**/*.doc
Drafts/**/*.docx
Drafts/**/*.ppt
Drafts/**/*.pptx
Drafts/**/*.xls
Drafts/**/*.xlsx
Drafts/**/*.png
Drafts/**/*.jpg
Drafts/**/*.jpeg
Drafts/**/*.gif
Drafts/**/*.mp3
Drafts/**/*.mp4
Drafts/**/*.mov
Drafts/**/*.wav
Drafts/**/*.zip
Drafts/**/*.tar
Drafts/**/*.gz
Drafts/**/*.tgz
Drafts/**/*.7z
